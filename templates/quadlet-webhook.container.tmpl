[Unit]
Description=Quadlet Deploy Webhook
After=network-online.target
Wants=network-online.target

[Container]
Image={{WEBHOOK_IMAGE}}
ContainerName=quadlet-webhook
PublishPort=127.0.0.1:{{WEBHOOK_LOCAL_PORT}}:8080
Environment=SALT_SECRET={{SALT_SECRET}}
Environment=VERSION_FILE=/data/global_version
Environment=TZ=UTC
Environment=TOKEN_TOLERANCE_MINUTES={{TOKEN_TOLERANCE_MINUTES}}
Environment=MAX_HEADER_VALUE_LEN=128
Volume={{VERSION_DIR}}:/data:Z
NoNewPrivileges=true
ReadOnly=true

[Service]
Restart=always
RestartSec=2
ReadWritePaths=/data

[Install]
WantedBy=multi-user.target
