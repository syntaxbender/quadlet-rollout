SALT_SECRET=replace_with_long_random_secret
VERSION_FILE=/opt/quadlet-rollout/global_version
STATUS_DIR=/opt/quadlet-rollout/status
NGINX_STATUS_FILE=/opt/quadlet-rollout/status/nginx/seen_version
NGINX_FAILED_VERSION_FILE=/opt/quadlet-rollout/nginx_failed_version
# Optional: if set, GET /check requires X-Check-Token.
CHECK_TOKEN=
PORT=8080
BIND=0.0.0.0
# Keep webhook runtime on UTC for deterministic token windows.
TZ=UTC
# Accept token windows around current time (+/- minutes).
TOKEN_TOLERANCE_MINUTES=5
MAX_HEADER_VALUE_LEN=128
