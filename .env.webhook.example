SALT_SECRET=replace_with_long_random_secret
VERSION_FILE=/opt/quadlet-rollout/global_version
PORT=8080
BIND=0.0.0.0
# Keep webhook runtime on UTC for deterministic token windows.
TZ=UTC
# Keep at 0 unless GitHub runner and webhook host clocks differ slightly.
CLOCK_SKEW_MINUTES=0
# Backward compatibility (deprecated name):
TZ_OFFSET_MINUTES=0
MAX_HEADER_VALUE_LEN=128
