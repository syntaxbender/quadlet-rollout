# /etc/quadlet-rollout/nginx-rollout.env
PROJECT_DIR=/opt/quadlet-rollout
GLOBAL_VERSION_FILE=/opt/quadlet-rollout/global_version

# Shared repo with both quadlet containers and nginx rollout definitions.
REPO_URL=https://github.com/syntaxbender/quadlet-services.git
REPO_DIR=/opt/quadlet-rollout/repos/quadlet-nginx-shared-repo

# Repo-relative paths.
NGINX_HTTP_DIR=nginx/http
NGINX_HTTPS_DIR=nginx/https
CERT_BUNDLES_DIR=nginx/cert-bundles

# Host paths.
NGINX_SITE_AVAILABLE_DIR=/etc/nginx/sites-available
NGINX_SITE_ENABLED_DIR=/etc/nginx/sites-enabled
ACME_CHALLENGE_ROOT=/var/www/certbot
STATE_FILE=/opt/quadlet-rollout/nginx_seen_version
CERTBOT_BIN=/usr/bin/certbot
